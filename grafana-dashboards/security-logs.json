{
  "title": "Security Logs",
  "uid": "security-logs",
  "schemaVersion": 36,
  "version": 3,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 10,
      "title": "Successful SSH Logins (rate)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({unit=\"sshd.service\"} |~ \"Accepted (publickey|password|keyboard-interactive) for\" [5m]))",
          "queryType": "range",
          "refId": "A",
          "legendFormat": "successful logins / 5m"
        }
      ]
    },
    {
      "id": 11,
      "title": "Successful SSH Logins (log)",
      "type": "logs",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{unit=\"sshd.service\"} |~ \"Accepted (publickey|password|keyboard-interactive) for\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "options": { "dedupStrategy": "none", "showTime": true, "showLabels": false, "wrapLogMessage": true, "sortOrder": "Descending" }
    },
    {
      "id": 1,
      "title": "SSH Connection Rate (all attempts)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({unit=\"sshd.service\"} [5m]))",
          "queryType": "range",
          "refId": "A",
          "legendFormat": "sshd events / 5m"
        }
      ]
    },
    {
      "id": 2,
      "title": "Failed / Invalid Login Rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 6 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "red" } },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({unit=\"sshd.service\"} |~ \"Failed|Invalid\" [5m]))",
          "queryType": "range",
          "refId": "A",
          "legendFormat": "failed logins / 5m"
        }
      ]
    },
    {
      "id": 3,
      "title": "SSH — Failed & Invalid Logins",
      "type": "logs",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 7 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{unit=\"sshd.service\"} |~ \"Failed|Invalid user|Invalid\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "options": { "dedupStrategy": "none", "showTime": true, "showLabels": false, "wrapLogMessage": true, "sortOrder": "Descending" }
    },
    {
      "id": 4,
      "title": "fail2ban — Bans",
      "type": "logs",
      "gridPos": { "x": 0, "y": 25, "w": 24, "h": 7 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{unit=\"fail2ban.service\"} |~ \"Ban|Found\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "options": { "dedupStrategy": "none", "showTime": true, "showLabels": false, "wrapLogMessage": true, "sortOrder": "Descending" }
    },
    {
      "id": 5,
      "title": "SSH — All Authentication Activity",
      "type": "logs",
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{unit=\"sshd.service\"} |~ \"Accepted|Failed|Invalid|Disconnected|session opened|session closed\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "options": { "dedupStrategy": "none", "showTime": true, "showLabels": false, "wrapLogMessage": true, "sortOrder": "Descending" }
    },
    {
      "id": 6,
      "title": "fail2ban — Service Activity",
      "type": "logs",
      "gridPos": { "x": 0, "y": 40, "w": 24, "h": 7 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{unit=\"fail2ban.service\"}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "options": { "dedupStrategy": "none", "showTime": true, "showLabels": false, "wrapLogMessage": true, "sortOrder": "Descending" }
    }
  ]
}
